{
  "name": "video-optimizer",
  "version": "1.0.0",
  "description": "Local web UI for optimizing videos with ffmpeg",
  "type": "module",
  "author": "Artem Repnikov",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "tsc -p tsconfig.client.json && tsx server.ts",
    "dev": "tsc -p tsconfig.client.json --watch & tsx watch server.ts",
    "build": "tsc -p tsconfig.client.json"
  },
  "dependencies": {
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
